# ---------------------------------------------------------------------------
# Big4India — environment variables
# Copy this file to `.env.local` for local development. In production, set the
# same variables in Vercel → Settings → Environment Variables.
# Everything here is OPTIONAL: with no variables set, leads are validated and
# logged to the server console (the form still works).
# ---------------------------------------------------------------------------

# Lead notifications via Resend (https://resend.com).
# 1. Create a free account, then create an API key (starts with "re_").
# 2. Paste it here / into Vercel. Each form submission then emails you.
RESEND_API_KEY=

# Where lead notifications are sent. Defaults to contact@big4india.com.
LEAD_NOTIFICATION_EMAIL=contact@big4india.com

# The "from" address shown on notification emails.
# For quick testing use the shared sender below (only delivers to your Resend
# account's own email). After you verify big4india.com in Resend, switch to a
# branded sender, e.g.  Big4India Leads <leads@big4india.com>
LEAD_FROM_EMAIL=Big4India Leads <onboarding@resend.dev>
